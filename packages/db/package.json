{
  "name": "@repo/db",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./index.ts",
    "./generated/prisma/client": "./generated/prisma/client.ts"
  },
  "scripts": {
    "db:generate": "bun --bun run prisma generate",
    "db:push": "bun --bun run prisma db push",
    "db:migrate": "bun --bun run prisma migrate dev",
    "db:studio": "bun --bun run prisma studio"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prisma": "^7.8.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@repo/secrets": "*"
  }
}
