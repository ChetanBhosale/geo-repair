// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  GITHUB
  GOOGLE
  FRAMER
  WORDPRESS
}

// Lifecycle of one scan run.
enum ScrapingStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

// Where a log came from, so one table serves every subsystem.
enum LogSource {
  SCRAPING
  AGENT
  SYSTEM
}

// Which background subsystem a worker job belongs to.
enum WorkerService {
  SCRAPING
  AGENT
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

// One human = one User. `email` is the account-linking key.
model User {
  id            String   @id @default(cuid())
  email         String?  @unique
  emailVerified Boolean  @default(false)
  name          String?
  username      String?
  avatarUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts     Account[]
  projects     Project[]
  scrapings    Scraping[]
  logs         Log[]
  workerStatus WorkerStatus[]

  @@map("users")
}

model Account {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider          AuthProvider
  providerAccountId String
  email             String?
  username          String?
  avatarUrl         String?

  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  tokenType             String?
  scope                 String?

  // Set only on GITHUB accounts that granted repo access.
  githubInstallationId BigInt?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@index([userId])
  @@map("accounts")
}

model Project {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // The GitHub account whose token/installation grants access to this repo.
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // Repo identity + the bits needed to clone and open a PR.
  githubRepoId  BigInt
  name          String
  fullName      String
  owner         String
  private       Boolean @default(false)
  htmlUrl       String
  cloneUrl      String
  defaultBranch String
  description   String?
  language      String?

  // Website the user wants fixed, and whether it was confirmed to match the repo.
  websiteUrl      String
  websiteVerified Boolean @default(false)
  // Why verification failed (repo does not match the website), if it did.
  websiteError    String?

  // The repo currently chosen for fixing.
  selected Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scrapings    Scraping[]
  logs         Log[]
  workerStatus WorkerStatus[]

  @@unique([userId, githubRepoId])
  @@index([userId])
  @@index([accountId])
  @@map("projects")
}

model Scraping {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  status     ScrapingStatus @default(QUEUED)
  websiteUrl String

  result Json?

  score        Int?
  scoreStatus  String? // SUCCESS | MID | FAILED
  pagesChecked Int     @default(0)
  pagesFailed  Int     @default(0)

  repoVerified   Boolean? // null = not checked yet
  repoConfidence Float?

  // Populated on FAILED or repo/website mismatch.
  error String?

  // Temporal handle. Null when run offline via the CLI.
  temporalWorkflowId String? @unique

  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  logs         Log[]
  workerStatus WorkerStatus?

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@map("scrapings")
}

model WorkerStatus {
  id                 String         @id @default(cuid())
  service            WorkerService
  status             ScrapingStatus @default(QUEUED)
  temporalWorkflowId String?        @unique

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Pointer to the run that holds the full result + logs (no result duplicated here).
  scrapingId String?   @unique
  scraping   Scraping? @relation(fields: [scrapingId], references: [id], onDelete: Cascade)

  // Small display fields for the list. No big JSON.
  title    String?
  progress Int? // optional 0-100 for a progress bar
  error    String?

  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId, status])
  @@index([projectId])
  @@map("worker_status")
}

// Generic append-only log. One pattern for scraping, agent, and system events.
model Log {
  id      String    @id @default(cuid())
  source  LogSource
  level   LogLevel  @default(INFO)
  // Event name, e.g. "repo_match", "page_scored", "check_failed".
  event   String
  message String?
  // Structured payload (check result, evidence, etc.).
  data    Json?
  // Ordering within a run.
  seq     Int       @default(0)

  // Optional links. A log belongs to a scraping now, an agent run later.
  projectId  String?
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scrapingId String?
  scraping   Scraping? @relation(fields: [scrapingId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([scrapingId, seq])
  @@index([projectId])
  @@index([source, event])
  @@map("logs")
}
