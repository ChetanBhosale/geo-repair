# PostHog analytics (US Cloud).
# The project key is a public, write-only key, safe to expose to the browser.
# Get it from PostHog: Project settings > Project API key (starts with "phc_").
NEXT_PUBLIC_POSTHOG_KEY=

# Events ingest through the Next.js reverse proxy (see rewrites in next.config.ts),
# so this is a same-origin relative path, not a posthog.com URL. Leave as-is.
NEXT_PUBLIC_POSTHOG_HOST=/ingest

# Preferred. Server-only backend origin used by the Next.js checkup proxy routes.
# Falls back to NEXT_PUBLIC_BACKEND_URL, then http://localhost:4000.
BACKEND_URL=

# Browser-visible backend origin used by the dashboard app.
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Browser-visible origin of the public scan API (the `/scan-website` route).
# Powers the landing-page free scan. In production this is the main API origin
# (https://api.geo.repair), which now mounts /scan-website directly; the
# standalone `free/` server in apps/backend-v2 serves the same route in dev.
NEXT_PUBLIC_OPEN_BACKEND_API=http://localhost:4100

# App origins used by backend redirects. WEB_URL receives payment returns,
# DASHBOARD_URL receives GitHub auth returns and fix/report workspace traffic.
WEB_URL=http://localhost:3001
DASHBOARD_URL=http://localhost:3000
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000

# Resend transactional email (server-side). Powers the waitlist welcome email and
# contact-form notification + acknowledgement. Get a key from resend.com > API Keys.
RESEND_API_KEY=

# Optional. Verified sender for outgoing email. The domain (geo.repair) must be
# verified in Resend. Defaults to "GEO Repair <hello@geo.repair>".
EMAIL_FROM=

# Optional. Inbox that receives contact-form submissions. Defaults to a team inbox.
CONTACT_NOTIFY_TO=

# Dodo Payments (server-side backend env, documented here for local setup).
# Use test_mode locally. The product IDs must point at one-time products named
# with customer-facing "AI Search Fix" language.
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PRODUCT_ID_STARTER=
DODO_PRODUCT_ID_GROWTH=
DODO_PRODUCT_ID_SCALE=

# Optional. Enables /api/dev/billing/fixture-order in local backend only.
ENABLE_DEV_BILLING_FIXTURES=false

# Internal agent-run cost estimates for local/dev visibility.
# Values are cents, not dollars. Example: 50 = $0.50 per million input tokens.
COGS_LLM_INPUT_CENTS_PER_MILLION_TOKENS=
COGS_LLM_OUTPUT_CENTS_PER_MILLION_TOKENS=
COGS_E2B_SANDBOX_CENTS_PER_HOUR=
COGS_IMAGE_CENTS_PER_THUMBNAIL=
